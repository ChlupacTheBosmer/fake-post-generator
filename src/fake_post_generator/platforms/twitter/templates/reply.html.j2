<!doctype html>
<html>
<head>
<meta charset="utf-8">
<style>
  html, body { margin: 0; padding: 0; }
  body {
    background: {{ page_bg }};
    font-family: TwitterChirp, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    padding: 16px;
  }
  .post-card {
    width: {{ layout.width }}px;
    box-sizing: border-box;
    background: {{ palette.bg }};
    color: {{ palette.text }};
    {% if show_border %}border: 1px solid {{ palette.border }};{% endif %}
    border-radius: 16px;
    padding: {{ layout.padding or 16 }}px;
  }
  .reply-header { display: flex; align-items: flex-start; gap: 10px; }
  .reply-avatar { width: 36px; height: 36px; border-radius: 50%; object-fit: cover; flex-shrink: 0; }
  .reply-id { flex: 1; }
  .reply-name-row {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-wrap: wrap;
    font-size: {{ (14 * layout.font_scale) | round(2) }}px;
  }
  .reply-name { font-weight: 700; }
  .reply-handle, .reply-time, .reply-dot { color: {{ palette.subtext }}; font-weight: 400; }
  .reply-menu { color: {{ palette.subtext }}; }
  .reply-text {
    margin: 6px 0 8px;
    white-space: pre-wrap;
    word-wrap: break-word;
    font-size: {{ (15 * layout.font_scale) | round(2) }}px;
    line-height: 1.4;
  }
  .reply-image { margin: 6px 0 10px; border-radius: 12px; overflow: hidden; border: 1px solid {{ palette.border }}; }
  .reply-image img { display: block; width: 100%; height: auto; }
  .reply-stats {
    display: flex;
    justify-content: space-between;
    gap: 8px;
    color: {{ palette.subtext }};
    font-size: {{ (12 * layout.font_scale) | round(2) }}px;
  }
  .reply-stats .stat { display: flex; align-items: center; gap: 4px; }
</style>
</head>
<body>
<div class="post-card">
  <div class="reply-header">
    <img class="reply-avatar" src="{{ avatar_uri }}" alt="">
    <div class="reply-id">
      <div class="reply-name-row">
        <span class="reply-name">{{ post.account.name }}</span>
        {% if verified_html %}{{ verified_html | safe }}{% endif %}
        <span class="reply-handle">@{{ post.account.handle }}</span>
        {% if post.time %}<span class="reply-dot">·</span><span class="reply-time">{{ post.time }}</span>{% endif %}
      </div>
    </div>
    <span class="reply-menu">{{ icon('more', 16, palette.subtext) | safe }}</span>
  </div>
  <div class="reply-text">{{ post.text }}</div>
  {% if post.image_url %}
  <div class="reply-image"><img src="{{ post.image_url }}" alt=""></div>
  {% endif %}
  {% if layout.reply_variant != 'compact' %}
  <div class="reply-stats">
    <div class="stat">{{ icon('reply', 14, palette.icon) | safe }}<span>{{ post.replies_count | humannum }}</span></div>
    <div class="stat">{{ icon('retweet', 14, palette.icon) | safe }}<span>{{ post.retweets | humannum }}</span></div>
    <div class="stat">{{ icon('like', 14, palette.icon) | safe }}<span>{{ post.likes | humannum }}</span></div>
    <div class="stat">{{ icon('view', 14, palette.icon) | safe }}<span>{{ post.views | humannum }}</span></div>
    <div class="stat">{{ icon('bookmark', 14, palette.icon) | safe }}{% if post.bookmarks %}<span>{{ post.bookmarks | humannum }}</span>{% endif %}</div>
    <div class="stat">{{ icon('share', 14, palette.icon) | safe }}</div>
  </div>
  {% endif %}
</div>
</body>
</html>
