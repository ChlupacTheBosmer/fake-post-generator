<!doctype html>
<html>
<head>
<meta charset="utf-8">
<style>
  html, body { margin: 0; padding: 0; }
  body {
    background: {{ page_bg }};
    font-family: TwitterChirp, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    padding: 12px;
  }
  .post-card {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: {{ palette.text }};
    font-size: {{ (16 * layout.font_scale) | round(2) }}px;
  }
  .avatar { width: 56px; height: 56px; border-radius: 50%; object-fit: cover; flex-shrink: 0; }
  .name-row { display: flex; align-items: center; gap: 4px; }
  .name { font-weight: 700; }
  .handle { color: {{ palette.subtext }}; font-weight: 400; font-size: {{ (14 * layout.font_scale) | round(2) }}px; }
</style>
</head>
<body>
<div class="post-card">
  <img class="avatar" src="{{ avatar_uri }}" alt="">
  <div>
    <div class="name-row">
      <span class="name">{{ post.account.name }}</span>
      {% if verified_html %}{{ verified_html | safe }}{% endif %}
    </div>
    <div class="handle">@{{ post.account.handle }}</div>
  </div>
</div>
</body>
</html>
